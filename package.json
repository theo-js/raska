{
  "name": "raska",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "npm run db:up && turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:up": "docker compose up -d",
    "prisma:studio": "npx prisma studio --config ./apps/backend/prisma.config.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4"
  }
}
